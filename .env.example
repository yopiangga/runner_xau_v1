# Salin file ini menjadi .env lalu isi nilainya.

# Sumber data: auto (Windows->mt5, lainnya->alltick) | alltick | mt5
DATA_PROVIDER=auto

# --- AllTick (REST API, lintas-platform) ---
ALLTICK_TOKEN=

# --- MT5 (Windows + MetaTrader 5) --- aktif jika DATA_PROVIDER=mt5/auto-di-Windows
MT5_SYMBOL=XAUUSD
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# --- Notifikasi Telegram (dikirim saat sinyal >= threshold) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
